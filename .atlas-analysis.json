  "keyFeatures": [
    "Full-stack React with TanStack Start",
    "Type-safe API layer with oRPC",
    "Authentication with Better Auth (OAuth + Email OTP)",
    "Database ORM with Prisma",
    "UI components with shadcn/ui and Tailwind CSS",
    "Form handling with React Hook Form",
    "Email templates with React Email",
    "File uploads with Better Upload",
    "Internationalization (i18n) with i18next",
    "Component development with Storybook",
    "Testing with Vitest and Playwright",
    "Docker Compose for local development"
  ],
  "publicApiSurface": [
    "account router - Profile management endpoints",
    "user router - User CRUD operations (admin)",
    "book router - Book catalog management",
    "genre router - Genre management",
    "config router - Application configuration",
    "auth endpoints - OAuth, email OTP, session management",
    "openapi endpoint - Interactive API documentation"
  ]
